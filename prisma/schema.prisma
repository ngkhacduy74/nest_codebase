generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String                  @id @default(uuid())
  email         String                  @unique
  passwordHash  String                  @map("password_hash")
  fullName      String?                 @map("full_name")
  locale        String                  @default("vi")
  timezone      String                  @default("Asia/Ho_Chi_Minh")
  avatarUrl     String?                 @map("avatar_url")
  systemRole    SystemRole              @default(user) @map("system_role")
  isActive      Boolean                 @default(true) @map("is_active")
  lastLoginAt   DateTime?               @map("last_login_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  trees         FamilyTree[]
  notifications Notification[]
  preferences   NotificationPreference?
  refreshTokens RefreshToken[]
  treeMembers   TreeMember[]

  @@index([systemRole])
  @@index([isActive])
  @@index([createdAt])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model FamilyTree {
  id                String             @id @default(uuid())
  ownerId           String             @map("owner_id")
  name              String
  description       String?
  coverUrl          String?            @map("cover_url")
  isPublic          Boolean            @default(false) @map("is_public")
  memberCount       Int                @default(0) @map("member_count")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  events            Event[]
  stories           FamilyStory[]
  owner             User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  persons           Person[]
  personAttachments PersonAttachment[]
  members           TreeMember[]

  @@index([ownerId])
  @@index([isPublic])
  @@index([createdAt])
}

model TreeMember {
  id        String     @id @default(uuid())
  treeId    String     @map("tree_id")
  userId    String     @map("user_id")
  role      TreeRole   @default(viewer)
  invitedBy String?    @map("invited_by")
  joinedAt  DateTime   @default(now()) @map("joined_at")
  tree      FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([treeId, userId])
  @@index([treeId])
  @@index([userId])
  @@index([treeId, role])
}

model Person {
  id               String             @id @default(uuid())
  treeId           String             @map("tree_id")
  fullName         String             @map("full_name")
  nickname         String?
  gender           Gender?
  lineageSide      LineageSide?       @map("lineage_side")
  birthDate        DateTime?          @map("birth_date")
  deathDate        DateTime?          @map("death_date")
  isAlive          Boolean            @default(true) @map("is_alive")
  avatarUrl        String?            @map("avatar_url")
  biography        String?
  occupation       String?
  generationNumber Int?               @map("generation_number")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  events           Event[]
  tree             FamilyTree         @relation(fields: [treeId], references: [id], onDelete: Cascade)
  attachments      PersonAttachment[]
  relationshipsA   Relationship[]     @relation("PersonA")
  relationshipsB   Relationship[]     @relation("PersonB")
  storyLinks       StoryPerson[]

  @@index([treeId])
  @@index([treeId, lineageSide])
  @@index([treeId, isAlive])
  @@index([treeId, deletedAt])
  @@index([treeId, createdAt])
  @@index([fullName])
}

model Relationship {
  id           String                 @id @default(uuid())
  treeId       String                 @map("tree_id")
  personAId    String                 @map("person_a_id")
  personBId    String                 @map("person_b_id")
  type         RelationshipType       @map("relationship_type")
  direction    RelationshipDirection?
  marriageDate DateTime?              @map("marriage_date")
  divorceDate  DateTime?              @map("divorce_date")
  createdAt    DateTime               @default(now()) @map("created_at")
  personA      Person                 @relation("PersonA", fields: [personAId], references: [id], onDelete: Cascade)
  personB      Person                 @relation("PersonB", fields: [personBId], references: [id], onDelete: Cascade)

  @@unique([treeId, personAId, personBId, type])
  @@index([personAId])
  @@index([personBId])
  @@index([treeId])
  @@index([treeId, type])
}

model Event {
  id              String         @id @default(uuid())
  treeId          String         @map("tree_id")
  personId        String?        @map("person_id")
  eventType       EventType      @map("event_type")
  title           String
  description     String?
  isAutoGenerated Boolean        @default(false) @map("is_auto_generated")
  eventDate       DateTime       @map("event_date")
  endDate         DateTime?      @map("end_date")
  isLunar         Boolean        @default(false) @map("is_lunar")
  lunarMonth      Int?           @map("lunar_month")
  lunarDay        Int?           @map("lunar_day")
  isRecurring     Boolean        @default(true) @map("is_recurring")
  reminderDays    Int[]          @default([7, 3, 1, 0]) @map("reminder_days")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  person          Person?        @relation(fields: [personId], references: [id])
  tree            FamilyTree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  notifications   Notification[]

  @@index([treeId])
  @@index([eventDate])
  @@index([treeId, eventType])
  @@index([personId])
  @@index([treeId, eventDate, eventType])
  @@index([treeId, lunarMonth, lunarDay])
}

model Notification {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  eventId     String?            @map("event_id")
  type        NotificationType
  title       String
  body        String?
  scheduledAt DateTime           @map("scheduled_at")
  sentAt      DateTime?          @map("sent_at")
  readAt      DateTime?          @map("read_at")
  status      NotificationStatus @default(pending)
  retryCount  Int                @default(0) @map("retry_count")
  createdAt   DateTime           @default(now()) @map("created_at")
  event       Event?             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([scheduledAt])
  @@index([userId, readAt])
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(false)
  inAppEnabled Boolean  @default(true)
  reminderDays Int[]    @default([7, 3, 1, 0])
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonAttachment {
  id        String         @id @default(uuid())
  personId  String
  treeId    String
  type      AttachmentType
  url       String
  filename  String?
  isAvatar  Boolean        @default(false)
  createdAt DateTime       @default(now())
  person    Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  tree      FamilyTree     @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([treeId])
}

model FamilyStory {
  id        String        @id @default(uuid())
  treeId    String
  title     String
  content   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tree      FamilyTree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  persons   StoryPerson[]

  @@index([treeId])
}

model StoryPerson {
  storyId  String
  personId String
  person   Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  story    FamilyStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, personId])
}

model SystemAnnouncement {
  id          String           @id @default(uuid())
  title       String
  content     String
  type        AnnouncementType @default(info)
  isActive    Boolean          @default(true)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())

  @@index([isActive, expiresAt])
}

enum SystemRole {
  admin
  user
}

enum TreeRole {
  owner
  editor
  viewer
}

enum Gender {
  male
  female
  unknown
}

enum LineageSide {
  paternal
  maternal
  self
}

enum RelationshipType {
  parent_child
  spouse
  adopted_parent_child
  step_parent_child
}

enum RelationshipDirection {
  a_is_parent
  b_is_parent
}

enum EventType {
  death_anniversary
  birthday
  wedding_anniversary
  tet
  holiday
  custom
}

enum NotificationType {
  in_app
  email
  push
  system
}

enum NotificationStatus {
  pending
  sent
  failed
  read
  cancelled
}

enum AttachmentType {
  photo
  document
  audio
}

enum AnnouncementType {
  info
  warning
  maintenance
}
