# =============================================================================
# NESTJS APPLICATION CONFIGURATION
# =============================================================================
# Application Environment
NODE_ENV=development

# Server Configuration
PORT=3000
APP_NAME=NestJS SaaS Backend
API_PREFIX=api/v1
API_VERSION=1.0.0
SHUTDOWN_TIMEOUT_MS=10000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database Connection URL (REQUIRED)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Database Pool Configuration
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_ACQUIRE_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000

# Database Retry Configuration
DB_RETRY_MAX=3
DB_RETRY_DELAY_MS=1000
DB_RETRY_BACKOFF=2

# Database Query Logging
DB_SLOW_QUERY_MS=1000

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis Server Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_CLUSTER=false

# Cache Configuration
CACHE_DEFAULT_TTL_MS=60000
CACHE_KEY_PREFIX=saas

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT Secrets (REQUIRED - Generate strong secrets for production)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# JWT Expiration Times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration
MAX_ACTIVE_SESSIONS=5

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting Configuration
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log Level: fatal, error, warn, info, debug, trace
LOG_LEVEL=debug

# Log Provider: console, pino
LOG_PROVIDER=console

# Correlation ID Header
CORRELATION_ID_HEADER=x-correlation-id

# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================
# Queue Retry Configuration
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_MS=1000
QUEUE_CONCURRENCY=10
QUEUE_REMOVE_COMPLETE=100
QUEUE_REMOVE_FAIL=50

# =============================================================================
# INTEGRATION PROVIDERS CONFIGURATION
# =============================================================================
# Email Provider (REQUIRED: sendgrid | ses | mailgun)
EMAIL_PROVIDER=sendgrid

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your App Name

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=your-aws-access-key
SES_SECRET_ACCESS_KEY=your-aws-secret-key
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=Your App Name

# Storage Provider (REQUIRED: aws-s3 | cloudinary | google-cloud)
STORAGE_PROVIDER=aws-s3

# AWS S3 Configuration (if STORAGE_PROVIDER=aws-s3)
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_ACCESS_KEY_ID=your-aws-access-key
AWS_S3_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_DOMAIN=amazonaws.com
AWS_S3_VALIDATION_MAX_KEYS=1

# Cloudinary Configuration (if STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret
CLOUDINARY_FOLDER=your-app-folder

# Payment Provider (REQUIRED: stripe | paypal | adyen)
PAYMENT_PROVIDER=stripe

# Stripe Configuration (if PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# SMS Provider (REQUIRED: twilio | vonage | aws-sns)
SMS_PROVIDER=twilio

# Twilio Configuration (if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=ACyourtwilioaccountsid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# =============================================================================
# ADDITIONAL CONFIGURATION
# =============================================================================
# Password Reset Configuration
PASSWORD_RESET_EXPIRES_IN_HOURS=1

# Storage Signed URL Configuration
STORAGE_SIGNED_URL_EXPIRES_IN=3600

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# 1. Copy this file to .env and update with your actual values
# 2. Never commit .env file to version control
# 3. Generate strong JWT secrets for production environments
# 4. Use environment-specific .env files like .env.production, .env.staging
# 5. All required fields will cause app to fail fast on startup if missing
# 6. Choose providers based on your needs and configure accordingly
# 7. Test provider configurations before deploying to production
