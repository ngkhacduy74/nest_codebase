#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "${YELLOW}Validating commit message format...${NC}"

# Run commitlint
if ! pnpm dlx commitlint --edit "$1"; then
  echo "${RED}✗ Commit message validation failed${NC}"
  echo "${YELLOW}Commit message must follow Conventional Commits format:${NC}"
  echo "  <type>[optional scope]: <description>"
  echo ""
  echo "Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
  exit 1
fi

echo "${GREEN}✓ Commit message format is valid${NC}"

exit 0
